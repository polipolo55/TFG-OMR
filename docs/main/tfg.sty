%% tfg.sty  —  TFG-OMR project style
%% Mirrors the colour palette defined in src/style.py.
%%
%% Usage:  \usepackage{tfg}   (place tfg.sty next to main.tex)
%%
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{tfg}[2026/02/23 TFG-OMR project style]

% ── Dependencies ───────────────────────────────────────────────────────────────
\RequirePackage[table,dvipsnames]{xcolor}
\RequirePackage{booktabs}      % better tables
\RequirePackage{microtype}     % better text rendering
\RequirePackage{hyperref}      % clickable refs (load last usually, but here is fine)
\RequirePackage{caption}       % caption customisation
\RequirePackage{subcaption}    % subfigures

% ── Palette  (mirrors src/style.py PALETTE) ────────────────────────────────────
%  Primary
\definecolor{tfgPrimary}      {HTML}{1565C0}
\definecolor{tfgPrimaryLight} {HTML}{42A5F5}
%  Secondary
\definecolor{tfgSecondary}      {HTML}{E65100}
\definecolor{tfgSecondaryLight} {HTML}{FFA726}
%  Tertiary
\definecolor{tfgTertiary}      {HTML}{2E7D32}
\definecolor{tfgTertiaryLight} {HTML}{81C784}
%  Highlight
\definecolor{tfgHighlight}      {HTML}{880E4F}
\definecolor{tfgHighlightLight} {HTML}{F06292}
%  Neutrals
\definecolor{tfgNeutralDark}  {HTML}{212121}
\definecolor{tfgNeutralMid}   {HTML}{757575}
\definecolor{tfgNeutralLight} {HTML}{E0E0E0}

% ── Hyperref colours ───────────────────────────────────────────────────────────
\hypersetup{
    colorlinks  = true,
    linkcolor   = tfgPrimary,
    citecolor   = tfgTertiary,
    urlcolor    = tfgSecondary,
    filecolor   = tfgSecondary,
    pdfborder   = {0 0 0},
}

% ── Caption style ──────────────────────────────────────────────────────────────
\captionsetup{
    font        = small,
    labelfont   = {bf, color=tfgNeutralDark},
    textfont    = {color=tfgNeutralMid},
    labelsep    = period,
    skip        = 6pt,
}

% ── Table helpers ──────────────────────────────────────────────────────────────
%  \rowA / \rowB for alternating shading; use inside tabular after \rowcolor{...}
\colorlet{tfgRowA}{tfgNeutralLight!40}
\colorlet{tfgRowB}{white}

% Shortcut: \tfgheadrule  —  coloured top rule for booktabs tables
\newcommand{\tfgheadrule}{\arrayrulecolor{tfgPrimary}\toprule\arrayrulecolor{black}}

% ── Inline emphasis ────────────────────────────────────────────────────────────
\newcommand{\code}[1]{\texttt{\color{tfgSecondary}#1}}
\newcommand{\term}[1]{\textit{\color{tfgPrimary}#1}}      % first use of a term
\newcommand{\important}[1]{\textbf{\color{tfgHighlight}#1}}

