# Copy this file to .env and fill in the values you need.
# The API server loads .env automatically on startup.

# --- CRNN model checkpoint ---
# Absolute or relative-to-project path. Default: models/latest/best_model.pt
# OMR_CHECKPOINT=models/latest/best_model.pt

# --- Chord OCR backend ---
# "vlm"     → send chord strip to GPT-4o / Gemini (requires API key below)
# "easyocr" → run EasyOCR locally (no key needed, weaker on handwritten fonts)
# Unset     → auto: vlm if any API key present, otherwise easyocr
# OMR_CHORD_BACKEND=vlm

# --- VLM API keys (only needed for OMR_CHORD_BACKEND=vlm) ---
# Set ONE of these. If both are set, OpenAI is used.
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=AIza...

# --- VLM model override ---
# Default: gpt-4o-mini (OpenAI) or gemini-2.0-flash (Google)
# OMR_VLM_MODEL=gpt-4o

# --- Inference options ---
# CTC beam width for CRNN decoding. 1 = greedy (fast), >1 = beam search (slower, sometimes better)
# OMR_BEAM_WIDTH=1

# --- PDF rendering ---
# DPI for PyMuPDF rasterisation (72–600). Higher = slower but more detail.
# OMR_PDF_DPI=300

# --- Debug ---
# If set, intermediate music/chord crop images are saved here for inspection.
# OMR_DEBUG_DIR=/tmp/omr_debug
