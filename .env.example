# Copy this file to .env and fill in the values you need.
# The API server loads .env automatically on startup.

# --- CRNN model checkpoint ---
# Absolute or relative-to-project path. Default: models/latest/best_model.pt
# OMR_CHECKPOINT=models/latest/best_model.pt

# --- Inference options ---
# CTC beam width for CRNN decoding. 1 = greedy (fast), >1 = beam search (slower, sometimes better)
# OMR_BEAM_WIDTH=1

# --- PDF rendering ---
# DPI for PyMuPDF rasterisation (72–600). Higher = slower but more detail.
# OMR_PDF_DPI=300

# --- Debug ---
# If set, intermediate music/chord crop images are saved here for inspection.
# OMR_DEBUG_DIR=/tmp/omr_debug
