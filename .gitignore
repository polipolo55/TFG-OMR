# Python
__pycache__/
*.pyc
.ipynb_checkpoints/
.venv/
env/

# Data (NEVER commit these)
data/raw/*
data/processed/*
!data/raw/.gitkeep      # Keeps the folder structure but ignores files
!data/processed/.gitkeep

# Large Models (GitHub has a 100MB limit)
models/*.pt
models/*.pth
models/*.onnx

# LaTeX / TeX (generated artifacts)
*.aux
*.fdb_latexmk
*.fls
*.fmt
*.fot
*.lof
*.log
*.lot
*.out
*.toc
*.synctex.gz
*.xdv

# Bibliography (BibTeX / Biber)
*.bbl
*.bcf
*.blg
*.run.xml

# Index / glossary / nomenclature
*.acn
*.acr
*.alg
*.glg
*.glo
*.gls
*.idx
*.ilg
*.ind
*.ist
*.loa
*.lol
*.nlo
*.nls

# Beamer / presentations
*.nav
*.snm

# Build helpers / temporary files
*.dvi
*.ps
*.backup
*.sav
*.tmp
*~

# Package-specific temp folders
_minted*/
pythontex-files-*/
